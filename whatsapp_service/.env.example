# Copy to whatsapp_service/.env and fill in. NEVER commit .env (gitignored).

# ── Supabase ────────────────────────────────────────────────────────────────
# Same values as .streamlit/secrets.toml. The service key bypasses RLS.
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=

# The nutritionist's auth uuid (Supabase dashboard → Authentication → Users →
# copy the UID). Every service-side write stamps this as owner_id so the rows
# appear in HER console. Single-tenant MVP: one value.
NUTRITIONIST_USER_ID=

# ── Twilio (slice 2 — leave empty until the sandbox exists) ─────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox sender, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=
# Her personal number in E.164 (+521...); it must have joined the sandbox.
NUTRITIONIST_WA_NUMBER=

# ── Claude drafting (slice 2) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Intake form link (slice 2+) ─────────────────────────────────────────────
# Base URL of the deployed Streamlit app (no trailing slash).
INTAKE_BASE_URL=https://<app>.streamlit.app
# Long random string; the SAME value goes in .streamlit/secrets.toml so the
# intake page can verify link tokens. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTAKE_LINK_SECRET=

# ── Local dev only ──────────────────────────────────────────────────────────
# true = webhook accepts requests without a Twilio signature (for curl tests).
# MUST be false (or removed) once Twilio points at this service.
DEV_SKIP_TWILIO_SIGNATURE=true
